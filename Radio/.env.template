# ─── Ollama (Local LLM — No API Key Needed) ───────────────────────────────
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ─── Local Embeddings (sentence-transformers — No API Key Needed) ──────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Notifications ────────────────────────────────────────────────────────
# Alerts are saved to alerts.json and displayed on the web dashboard.
# No Telegram or external service needed.

# ─── Sentry Mode ──────────────────────────────────────────────────────────
# Options: epi | eco | supply | general
SENTRY_MODE=general

# ─── Alert Threshold ──────────────────────────────────────────────────────
# Minimum relevance score (0.0–1.0) required to trigger full analysis
ALERT_THRESHOLD=0.4

# ─── RSS Feeds (India-focused) ────────────────────────────────────────────

# Epi-Sentry feeds (health & disease — India)
EPI_FEEDS=https://health.economictimes.indiatimes.com/rss/topstories,https://timesofindia.indiatimes.com/rssfeeds/3908999.cms,https://indianexpress.com/section/lifestyle/health/feed/

# Eco-Sentry feeds (climate & disasters — India)
ECO_FEEDS=https://timesofindia.indiatimes.com/rssfeeds/2647163.cms,https://www.ndtv.com/rss/india,https://indianexpress.com/section/india/feed/,https://reliefweb.int/updates/rss.xml?country=119

# Supply-Sentry feeds (industry & supply chain — India)
SUPPLY_FEEDS=https://economictimes.indiatimes.com/rssfeeds/1200853.cms,https://www.livemint.com/rss/companies,https://indianexpress.com/section/business/feed/

# General feeds (fallback — Indian news)
RSS_FEEDS=https://feeds.feedburner.com/ndtvnews-top-stories,https://timesofindia.indiatimes.com/rssfeedstopstories.cms

# Poll interval in seconds (default: 5 minutes)
POLL_INTERVAL=300

# ─── User Profile ─────────────────────────────────────────────────────────
USER_PROFILE_PATH=user_profile.json
